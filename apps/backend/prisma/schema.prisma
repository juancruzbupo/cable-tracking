generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  ACTIVO
  BAJA
}

enum DocumentType {
  RAMITO
  FACTURA
}

enum ServiceType {
  CABLE
  INTERNET
}

enum PromoType {
  PORCENTAJE
  MONTO_FIJO
  MESES_GRATIS
  PRECIO_FIJO
}

enum PromoScope {
  PLAN
  CLIENTE
}

enum TipoDocumento {
  CUIT
  CUIL
  DNI
  CONSUMIDOR_FINAL
}

enum CondicionFiscal {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTISTA
  CONSUMIDOR_FINAL
  EXENTO
}

enum TipoComprobante {
  FACTURA_A
  FACTURA_B
  FACTURA_C
  RECIBO_X
}

enum EstadoComprobante {
  PENDIENTE
  EMITIDO
  ANULADO
  ERROR
}

enum Role {
  ADMIN
  OPERADOR
  VISOR
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(OPERADOR)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  notes     ClientNote[]
  auditLogs AuditLog[]

  @@map("users")
}

model Client {
  id                 String         @id @default(uuid()) @db.Uuid
  codCli             String         @unique @map("cod_cli")
  nombreOriginal     String         @map("nombre_original")
  nombreNormalizado  String         @map("nombre_normalizado")
  fechaAlta          DateTime?      @map("fecha_alta") @db.Date
  estado             ClientStatus   @default(ACTIVO)
  calle              String?

  // Datos fiscales
  tipoDocumento      TipoDocumento?    @map("tipo_documento")
  numeroDocFiscal    String?           @map("numero_doc_fiscal")
  condicionFiscal    CondicionFiscal   @default(CONSUMIDOR_FINAL) @map("condicion_fiscal")
  razonSocial        String?           @map("razon_social")
  telefono           String?
  email              String?

  // Ubicación completa (ARCA factura electrónica)
  codigoPostal       String?           @map("codigo_postal")
  localidad          String?
  provincia          String?           @default("Entre Ríos")

  // Zona de cobranza (para organizar recorridos)
  zona               String?

  subscriptions      Subscription[]
  documents          Document[]
  paymentPeriods     PaymentPeriod[]
  notes              ClientNote[]
  comprobantes       Comprobante[]

  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  @@index([estado])
  @@index([nombreNormalizado])
  @@index([zona])
  @@map("clients")
}

model ServicePlan {
  id          String      @id @default(uuid()) @db.Uuid
  nombre      String
  tipo        ServiceType
  precio      Decimal     @db.Decimal(10, 2)
  descripcion String?
  activo      Boolean     @default(true)

  subscriptions Subscription[]
  promotions    Promotion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("service_plans")
}

model Subscription {
  id              String       @id @default(uuid()) @db.Uuid
  clientId        String       @map("client_id") @db.Uuid
  tipo            ServiceType
  fechaAlta       DateTime     @map("fecha_alta") @db.Date
  estado          ClientStatus @default(ACTIVO)
  planId          String?      @map("plan_id") @db.Uuid
  deudaCalculada  Int?         @map("deuda_calculada")
  requiereCorte   Boolean      @default(false) @map("requiere_corte")
  ultimoCalculo   DateTime?    @map("ultimo_calculo")

  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan             ServicePlan?      @relation(fields: [planId], references: [id], onDelete: SetNull)
  documents        Document[]
  paymentPeriods   PaymentPeriod[]
  clientPromotions ClientPromotion[]
  comprobantes     Comprobante[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, tipo])
  @@index([clientId])
  @@map("subscriptions")
}

model Document {
  id                  String        @id @default(uuid()) @db.Uuid
  clientId            String        @map("client_id") @db.Uuid
  codCli              String        @map("cod_cli")
  subscriptionId      String?       @map("subscription_id") @db.Uuid
  tipo                DocumentType
  fechaDocumento      DateTime?     @map("fecha_documento") @db.Date
  numeroDocumento     String?       @map("numero_documento")
  descripcionOriginal String?       @map("descripcion_original")
  formaPago           String?       @map("forma_pago")

  client              Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subscription        Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  paymentPeriods      PaymentPeriod[]

  createdAt           DateTime      @default(now()) @map("created_at")

  @@index([tipo])
  @@index([clientId])
  @@index([clientId, tipo])
  @@index([codCli])
  @@index([subscriptionId])
  @@map("documents")
}

model PaymentPeriod {
  id             String        @id @default(uuid()) @db.Uuid
  clientId       String        @map("client_id") @db.Uuid
  codCli         String        @map("cod_cli")
  documentId     String        @map("document_id") @db.Uuid
  subscriptionId String?       @map("subscription_id") @db.Uuid
  periodo        DateTime      @db.Date
  year           Int
  month          Int

  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  document       Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  comprobante    Comprobante?

  createdAt      DateTime      @default(now()) @map("created_at")

  @@unique([clientId, periodo, documentId])
  @@index([clientId, periodo])
  @@index([clientId, year, month])
  @@index([documentId])
  @@index([subscriptionId])
  @@map("payment_periods")
}

model ImportLog {
  id              String   @id @default(uuid()) @db.Uuid
  tipo            String
  fileName        String   @map("file_name")
  totalRows       Int      @map("total_rows")
  validRows       Int      @map("valid_rows")
  invalidRows     Int      @map("invalid_rows")
  newClients      Int      @default(0) @map("new_clients")
  updatedClients  Int      @default(0) @map("updated_clients")
  errors          Json?
  status          String   @default("SUCCESS")
  executedAt      DateTime @default(now()) @map("executed_at")

  @@index([tipo])
  @@index([executedAt])
  @@map("import_logs")
}

model ClientNote {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientId])
  @@map("client_notes")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?

  user       User     @relation(fields: [userId], references: [id])

  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Promotion {
  id          String     @id @default(uuid()) @db.Uuid
  nombre      String
  tipo        PromoType
  valor       Decimal    @db.Decimal(10, 2)
  scope       PromoScope
  fechaInicio DateTime   @map("fecha_inicio") @db.Date
  fechaFin    DateTime   @map("fecha_fin") @db.Date
  activa      Boolean    @default(true)
  descripcion String?
  planId      String?    @map("plan_id") @db.Uuid

  plan             ServicePlan?      @relation(fields: [planId], references: [id])
  clientPromotions ClientPromotion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([planId])
  @@index([fechaInicio, fechaFin])
  @@map("promotions")
}

model ClientPromotion {
  id             String       @id @default(uuid()) @db.Uuid
  promotionId    String       @map("promotion_id") @db.Uuid
  subscriptionId String       @map("subscription_id") @db.Uuid
  assignedBy     String       @map("assigned_by")

  promotion    Promotion    @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([promotionId, subscriptionId])
  @@index([subscriptionId])
  @@map("client_promotions")
}

model Comprobante {
  id                String            @id @default(uuid()) @db.Uuid
  clientId          String            @map("client_id") @db.Uuid
  subscriptionId    String?           @map("subscription_id") @db.Uuid
  paymentPeriodId   String?           @unique @map("payment_period_id") @db.Uuid

  tipo              TipoComprobante
  numero            Int
  puntoVenta        Int               @default(1) @map("punto_venta")
  fecha             DateTime          @db.Date

  emisorCuit        String            @map("emisor_cuit")
  emisorRazonSocial String            @map("emisor_razon_social")
  emisorCondicion   String            @map("emisor_condicion")
  receptorDoc       String            @map("receptor_doc")
  receptorNombre    String            @map("receptor_nombre")
  receptorCondicion String            @map("receptor_condicion")

  subtotal          Decimal           @db.Decimal(10, 2)
  descuento         Decimal           @db.Decimal(10, 2) @default(0)
  iva               Decimal           @db.Decimal(10, 2) @default(0)
  total             Decimal           @db.Decimal(10, 2)

  detalle           Json
  estado            EstadoComprobante @default(PENDIENTE)
  cae               String?
  caeFechaVto       DateTime?         @map("cae_fecha_vto")
  providerResponse  Json?             @map("provider_response")

  // Campos ARCA (ex-AFIP) para factura electrónica de servicios
  concepto          Int               @default(2)
  fechaServDesde    DateTime?         @map("fecha_serv_desde") @db.Date
  fechaServHasta    DateTime?         @map("fecha_serv_hasta") @db.Date
  fechaVtoPago      DateTime?         @map("fecha_vto_pago") @db.Date
  formaPago         String?           @default("CONTADO") @map("forma_pago")

  client            Client            @relation(fields: [clientId], references: [id])
  subscription      Subscription?     @relation(fields: [subscriptionId], references: [id])
  paymentPeriod     PaymentPeriod?    @relation(fields: [paymentPeriodId], references: [id])

  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([estado])
  @@index([fecha])
  @@map("comprobantes")
}

model EmpresaConfig {
  id              String   @id @default(uuid()) @db.Uuid
  cuit            String
  razonSocial     String   @map("razon_social")
  condicionFiscal String   @map("condicion_fiscal")
  domicilioFiscal String?  @map("domicilio_fiscal")
  ingresosBrutos  String?  @map("ingresos_brutos")
  fechaInicioAct  String?  @map("fecha_inicio_act")
  puntoVenta      Int      @default(1) @map("punto_venta")
  providerName    String   @default("mock") @map("provider_name")
  providerApiKey  String?  @map("provider_api_key")
  providerConfig  Json?    @map("provider_config")

  // Datos fiscales completos para PDF
  iibb            String?
  actividadCodigo String?  @default("613000") @map("actividad_codigo")
  localidad       String?
  logoUrl         String?  @map("logo_url")

  // Umbral de corte configurable (meses deuda > umbral = corte)
  umbralCorte     Int      @default(1) @map("umbral_corte")

  // Zona default para alta de clientes
  zonaDefault     String?  @map("zona_default")

  updatedAt       DateTime @updatedAt @map("updated_at")
  updatedBy       String?  @map("updated_by")

  @@map("empresa_config")
}
