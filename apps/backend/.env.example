# ══════════════════════════════════════════════════════════════
# Cable Tracking - Backend Environment Variables
# ══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# Local (Docker Compose):
DATABASE_URL="postgresql://cable_user:cable_pass@localhost:5432/cable_tracking?schema=public"

# Supabase (producción):
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────
# Local:
FRONTEND_URL=http://localhost:5174

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=cable-tracking-secret-dev-change-in-production

# Producción (Vercel):
# FRONTEND_URL=https://cable-tracking.vercel.app
